# ================================
# Flux-Capacitor - Variáveis de Ambiente
# ================================

# ---- OpenAI ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.6

# ---- LangFuse (observabilidade) ----
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# ---- Aplicação ----
APP_NAME=Flux-Capacitor
APP_VERSION=1.0.0
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ---- Banco ----
DATABASE_URL=sqlite+aiosqlite:///./data/flux_capacitor.db
DATABASE_SYNC_URL=sqlite:///./data/flux_capacitor.db

# ---- API ----
API_KEY_HEADER=X-API-Key
API_DEFAULT_KEY=change-me-flux-capacitor-key

# ---- CORS ----
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173

# ---- Unsplash (imagens placeholder) ----
UNSPLASH_BASE=https://source.unsplash.com
